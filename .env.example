APP_NAME=Inventario Operativo
ENVIRONMENT=local
# Conexion usada por FastAPI. En Supabase se recomienda el pooler de sesion.
DATABASE_URL=postgresql+psycopg://inventario:inventario@localhost:5432/inventario
# Para Supabase, la URL puede contener {password} y la clave se guarda por separado.
DATABASE_PASSWORD=
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_POOL_TIMEOUT_SECONDS=15
DATABASE_POOL_RECYCLE_SECONDS=300
# Conexion opcional usada solo por Alembic. En Supabase se recomienda la conexion directa.
# Si se deja vacia, Alembic usa DATABASE_URL.
MIGRATION_DATABASE_URL=
SESSION_COOKIE_NAME=inventory_session
SESSION_HOURS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
# En produccion agrega aqui el frontend publicado, por ejemplo:
# CORS_ORIGINS=["https://inventario-operativo.vercel.app"]
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
